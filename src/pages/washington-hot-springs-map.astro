---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Washington Hot Springs Map"
  description="Interactive map of all hot springs in Washington State with conditions, access info, and trip planning."
>
  <div class="map-page">
    <aside class="map-sidebar">
      <div class="sidebar-header">
        <h1>Hot Springs Map</h1>
        <p>Click a spring to see details</p>
      </div>

      <div class="search-box">
        <input
          type="search"
          id="spring-search"
          placeholder="Search springs..."
          autocomplete="off"
        />
      </div>

      <div id="springs-list" class="springs-list">
        <div class="loading-placeholder">Loading springs...</div>
      </div>
    </aside>

    <div class="map-container">
      <div id="map"></div>

      <!-- Spring detail panel -->
      <div id="spring-detail" class="spring-detail hidden">
        <button id="detail-close" class="detail-close" aria-label="Close">✕</button>
        <div id="detail-content"></div>
      </div>
    </div>
  </div>
</BaseLayout>

<!-- Leaflet CSS -->
<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
  crossorigin=""
/>

<script>
// ─── Map initialisation ────────────────────────────────────────────────────────
async function initMap() {
  // Dynamically import Leaflet (avoids SSR issues)
  const L = (await import('https://unpkg.com/leaflet@1.9.4/dist/leaflet-src.esm.js')).default ?? await import('https://unpkg.com/leaflet@1.9.4/dist/leaflet-src.esm.js');

  const map = L.map('map').setView([47.5, -120.7], 7);

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
    maxZoom: 18,
  }).addTo(map);

  // Custom marker icon
  const springIcon = L.divIcon({
    className: 'spring-marker',
    html: '<div class="marker-dot">♨</div>',
    iconSize: [32, 32],
    iconAnchor: [16, 16],
    popupAnchor: [0, -18],
  });

  // ─── Load springs ────────────────────────────────────────────────────────────
  let springs = [];
  try {
    const res = await fetch('/api/springs.json');
    springs = await res.json();
  } catch (e) {
    console.error('Failed to load springs:', e);
  }

  // ─── Render sidebar list ─────────────────────────────────────────────────────
  const listEl = document.getElementById('springs-list');
  const searchEl = document.getElementById('spring-search');

  function renderList(filtered) {
    if (!filtered.length) {
      listEl.innerHTML = '<p class="no-results">No springs found.</p>';
      return;
    }
    listEl.innerHTML = filtered.map(s => `
      <button class="spring-list-item" data-slug="${s.slug}">
        <span class="list-icon">♨</span>
        <div class="list-info">
          <strong>${s.name}</strong>
          <span>${s.temp_f ? s.temp_f + '°F' : '—'} · ${s.access_type ?? '—'} · ${s.fee != null ? (s.fee === 0 ? 'Free' : '$' + s.fee) : '—'}</span>
        </div>
      </button>
    `).join('');

    // Sidebar item → fly to + open detail
    listEl.querySelectorAll('.spring-list-item').forEach(btn => {
      btn.addEventListener('click', () => {
        const spring = springs.find(s => s.slug === btn.dataset.slug);
        if (spring) openDetail(spring, map);
      });
    });
  }

  renderList(springs);

  searchEl?.addEventListener('input', () => {
    const q = searchEl.value.toLowerCase();
    renderList(springs.filter(s => s.name.toLowerCase().includes(q)));
  });

  // ─── Place markers ───────────────────────────────────────────────────────────
  const markers = new Map();

  springs.forEach(spring => {
    if (!spring.lat || !spring.lng) return;

    const marker = L.marker([spring.lat, spring.lng], { icon: springIcon })
      .addTo(map)
      .bindTooltip(spring.name, { direction: 'top', offset: [0, -10] });

    marker.on('click', () => openDetail(spring, map));
    markers.set(spring.slug, marker);
  });

  // ─── Detail panel ────────────────────────────────────────────────────────────
  function openDetail(spring, map) {
    map.flyTo([spring.lat, spring.lng], 12, { duration: 0.8 });

    const detail = document.getElementById('spring-detail');
    const content = document.getElementById('detail-content');
    detail.classList.remove('hidden');

    const blogSlug = spring.slug;

    content.innerHTML = `
      <h2>${spring.name}</h2>
      <div class="detail-chips">
        ${spring.temp_f ? `<span class="chip">🌡 ${spring.temp_f}°F</span>` : ''}
        ${spring.fee != null ? `<span class="chip">💰 ${spring.fee === 0 ? 'Free' : '$' + spring.fee}</span>` : ''}
        ${spring.access_type ? `<span class="chip">🥾 ${spring.access_type}</span>` : ''}
        ${spring.season ? `<span class="chip">📅 ${spring.season}</span>` : ''}
      </div>
      ${spring.description ? `<p class="detail-desc">${spring.description}</p>` : ''}
      <dl class="detail-grid">
        ${spring.hours ? `<dt>Hours</dt><dd>${spring.hours}</dd>` : ''}
        ${spring.clothing ? `<dt>Clothing</dt><dd>${spring.clothing}</dd>` : ''}
        ${spring.parking ? `<dt>Parking</dt><dd>${spring.parking}</dd>` : ''}
        ${spring.cell_coverage ? `<dt>Cell</dt><dd>${spring.cell_coverage}</dd>` : ''}
        ${spring.road_condition ? `<dt>Road</dt><dd>${spring.road_condition}</dd>` : ''}
        ${spring.best_time ? `<dt>Best time</dt><dd>${spring.best_time}</dd>` : ''}
        ${spring.alerts ? `<dt>Alerts</dt><dd class="alert-text">${spring.alerts}</dd>` : ''}
      </dl>
      ${spring.insider_tips ? `<div class="insider-tip"><strong>💡 Insider tip:</strong> ${spring.insider_tips}</div>` : ''}
      <div class="detail-actions">
        <a href="/blog/${blogSlug}" class="btn-detail">Read full guide →</a>
        <a href="https://www.google.com/maps/dir/?api=1&destination=${spring.lat},${spring.lng}"
           target="_blank" rel="noopener" class="btn-detail btn-secondary">Directions ↗</a>
      </div>
    `;
  }

  document.getElementById('detail-close')?.addEventListener('click', () => {
    document.getElementById('spring-detail')?.classList.add('hidden');
  });
}

initMap();
</script>

<style>
  /* Full-height layout */
  .map-page {
    display: flex;
    height: calc(100vh - 60px); /* subtract header height */
    overflow: hidden;
  }

  /* Sidebar */
  .map-sidebar {
    width: 320px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    border-right: 1px solid var(--color-border);
    background: var(--color-surface);
    overflow: hidden;
  }
  .sidebar-header {
    padding: 1.25rem 1.25rem 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }
  .sidebar-header h1 { font-size: 1.25rem; font-weight: 700; margin-bottom: 0.2rem; }
  .sidebar-header p { font-size: 0.8125rem; color: var(--color-text-muted); }

  .search-box { padding: 0.75rem 1.25rem; border-bottom: 1px solid var(--color-border); }
  .search-box input {
    width: 100%;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-size: 0.875rem;
    outline: none;
    background: var(--color-bg);
  }
  .search-box input:focus { border-color: var(--color-accent); }

  .springs-list { flex: 1; overflow-y: auto; padding: 0.5rem 0; }
  .loading-placeholder { padding: 1rem 1.25rem; color: var(--color-text-muted); font-size: 0.875rem; }
  .no-results { padding: 1rem 1.25rem; color: var(--color-text-muted); font-size: 0.875rem; }

  .spring-list-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    padding: 0.75rem 1.25rem;
    text-align: left;
    background: none;
    border: none;
    cursor: pointer;
    transition: background 0.1s;
  }
  .spring-list-item:hover { background: var(--color-bg); }
  .list-icon { font-size: 1.25rem; flex-shrink: 0; }
  .list-info { display: flex; flex-direction: column; min-width: 0; }
  .list-info strong { font-size: 0.9rem; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .list-info span { font-size: 0.75rem; color: var(--color-text-muted); margin-top: 0.1rem; }

  /* Map */
  .map-container { flex: 1; position: relative; }
  #map { width: 100%; height: 100%; }

  /* Custom marker */
  :global(.spring-marker) { background: none; border: none; }
  :global(.marker-dot) {
    width: 32px; height: 32px;
    background: var(--color-accent);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: white; font-size: 1rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.25);
    transition: transform 0.15s;
  }
  :global(.marker-dot:hover) { transform: scale(1.2); }

  /* Detail panel */
  .spring-detail {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    width: min(480px, calc(100% - 3rem));
    background: var(--color-surface);
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.18);
    padding: 1.5rem;
    z-index: 1000;
    max-height: 70vh;
    overflow-y: auto;
  }
  .spring-detail.hidden { display: none; }
  .detail-close {
    position: absolute; top: 1rem; right: 1rem;
    background: var(--color-bg); border: 1px solid var(--color-border);
    border-radius: 50%; width: 28px; height: 28px;
    cursor: pointer; font-size: 0.8rem; display: flex; align-items: center; justify-content: center;
  }
  .spring-detail h2 { font-size: 1.25rem; font-weight: 700; margin-bottom: 0.75rem; padding-right: 2rem; }

  .detail-chips { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 0.875rem; }
  .chip {
    background: var(--color-bg); border: 1px solid var(--color-border);
    border-radius: 20px; padding: 0.2rem 0.6rem;
    font-size: 0.75rem; font-weight: 500;
  }
  .detail-desc { font-size: 0.9rem; color: var(--color-text-muted); margin-bottom: 1rem; line-height: 1.6; }
  .detail-grid { display: grid; grid-template-columns: auto 1fr; gap: 0.3rem 0.75rem; font-size: 0.85rem; margin-bottom: 1rem; }
  .detail-grid dt { font-weight: 600; color: var(--color-text-muted); white-space: nowrap; }
  .detail-grid dd { color: var(--color-text); }
  .alert-text { color: #b45309; font-weight: 500; }
  .insider-tip {
    background: #f0fdf4; border: 1px solid #bbf7d0;
    border-radius: 8px; padding: 0.75rem; font-size: 0.85rem;
    margin-bottom: 1rem; line-height: 1.5;
  }
  .detail-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .btn-detail {
    display: inline-block; padding: 0.5rem 1rem;
    background: var(--color-accent); color: white;
    border-radius: 6px; font-size: 0.875rem; font-weight: 600;
    transition: background 0.15s;
  }
  .btn-detail:hover { background: var(--color-accent-light); color: white; }
  .btn-detail.btn-secondary {
    background: var(--color-bg); color: var(--color-text);
    border: 1px solid var(--color-border);
  }
  .btn-detail.btn-secondary:hover { background: var(--color-border); }

  /* Mobile */
  @media (max-width: 640px) {
    .map-page { flex-direction: column; }
    .map-sidebar { width: 100%; height: 220px; border-right: none; border-bottom: 1px solid var(--color-border); }
    .springs-list { display: flex; flex-direction: row; overflow-x: auto; overflow-y: hidden; padding: 0.5rem; gap: 0.5rem; }
    .spring-list-item { min-width: 180px; border: 1px solid var(--color-border); border-radius: 8px; }
  }
</style>
