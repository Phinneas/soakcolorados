---
import BaseLayout from '../layouts/BaseLayout.astro';

const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN ?? '';
const googleApiKey = import.meta.env.PUBLIC_GOOGLE_API_KEY ?? '';
---

<BaseLayout
  title="Hot Springs Trip Planner"
  description="Plan a multi-stop Colorado hot springs road trip with optimized routing, driving directions, and nearby amenities."
>
  <div class="planner-page">

    <!-- LEFT PANEL -->
    <aside class="planner-sidebar">
      <div class="sidebar-section">
        <h1 class="sidebar-title">Trip Planner</h1>

        <label class="field-label" for="start-location">Starting Location</label>
        <div class="start-input-row">
          <input
            type="text"
            id="start-location"
            placeholder="City, address, or ZIP..."
            autocomplete="off"
          />
          <button id="use-gps-btn" title="Use my location">📍</button>
        </div>
      </div>

      <div class="sidebar-section">
        <div class="section-header-row">
          <span class="field-label">Available Springs</span>
          <input type="search" id="spring-filter" placeholder="Filter..." />
        </div>
        <div id="springs-list" class="springs-checklist">
          <p class="muted">Loading springs…</p>
        </div>
      </div>

      <div class="sidebar-section">
        <div class="section-header-row">
          <span class="field-label">Your Trip <span id="selected-count" class="badge">0</span></span>
          <button id="clear-trip-btn" class="text-btn">Clear</button>
        </div>
        <div id="selected-list" class="selected-list">
          <p class="muted">Add springs from the list above.</p>
        </div>
        <button id="optimize-btn" class="btn-primary full-width" disabled>
          🗺 Optimize Route
        </button>
      </div>

      <!-- Route stats -->
      <div id="route-stats" class="sidebar-section hidden">
        <div class="stats-row">
          <div class="stat"><span id="stat-distance">—</span><small>miles</small></div>
          <div class="stat"><span id="stat-duration">—</span><small>drive time</small></div>
          <div class="stat"><span id="stat-stops">—</span><small>stops</small></div>
        </div>
        <div class="btn-row">
          <button id="save-trip-btn" class="btn-secondary">💾 Save</button>
          <button id="share-trip-btn" class="btn-secondary">🔗 Share</button>
        </div>
      </div>

      <!-- POI Recommendations -->
      <div id="poi-section" class="sidebar-section hidden">
        <span class="field-label">Nearby on Route</span>
        <div id="poi-list"></div>
      </div>
    </aside>

    <!-- MAP -->
    <div class="map-wrap">
      <div id="map"></div>
      <div id="loading-overlay" class="loading-overlay hidden">
        <div class="spinner"></div>
        <span id="loading-msg">Optimizing route…</span>
      </div>
    </div>

  </div>
</BaseLayout>

<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
  crossorigin=""
/>

<script define:vars={{ mapboxToken, googleApiKey }}>
// ─── Config ───────────────────────────────────────────────────────────────────
const CFG = {
  mapCenter: [39.0, -106.0], // Colorado
  mapZoom: 7,
  mapboxToken,
  googleApiKey,
  overpassUrl: 'https://overpass-api.de/api/interpreter',
};

// ─── State ────────────────────────────────────────────────────────────────────
let map, L;
let springs = [];
let selectedSprings = [];
let startLocation = null;
let markers = new Map();
let routeLayer = null;
let optimizedRoute = null;

// ─── Helpers ──────────────────────────────────────────────────────────────────
function haversineKm(lat1, lng1, lat2, lng2) {
  const R = 6371;
  const dLat = (lat2 - lat1) * Math.PI / 180;
  const dLng = (lng2 - lng1) * Math.PI / 180;
  const a = Math.sin(dLat/2)**2 + Math.cos(lat1*Math.PI/180) * Math.cos(lat2*Math.PI/180) * Math.sin(dLng/2)**2;
  return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
}

function formatDuration(seconds) {
  const h = Math.floor(seconds / 3600);
  const m = Math.floor((seconds % 3600) / 60);
  return h > 0 ? `${h}h ${m}m` : `${m}m`;
}

function setLoading(msg) {
  const el = document.getElementById('loading-overlay');
  document.getElementById('loading-msg').textContent = msg;
  el.classList.remove('hidden');
}
function clearLoading() { document.getElementById('loading-overlay').classList.add('hidden'); }

// ─── Init ─────────────────────────────────────────────────────────────────────
async function init() {
  L = (await import('https://unpkg.com/leaflet@1.9.4/dist/leaflet-src.esm.js')).default
    ?? await import('https://unpkg.com/leaflet@1.9.4/dist/leaflet-src.esm.js');

  map = L.map('map').setView(CFG.mapCenter, CFG.mapZoom);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenStreetMap contributors',
  }).addTo(map);

  // Load springs
  try {
    const res = await fetch('/api/springs.json');
    springs = await res.json();
  } catch (e) { console.error('Failed to load springs', e); }

  renderSpringsList();
  addSpringMarkers();
  restoreSavedTrip();
  setupListeners();
}

// ─── Markers ──────────────────────────────────────────────────────────────────
function makeIcon(selected) {
  return L.divIcon({
    className: 'spring-marker',
    html: `<div class="tp-marker ${selected ? 'tp-selected' : ''}">♨</div>`,
    iconSize: [30, 30], iconAnchor: [15, 15],
  });
}

function addSpringMarkers() {
  springs.forEach(s => {
    if (!s.lat || !s.lng) return;
    const m = L.marker([s.lat, s.lng], { icon: makeIcon(false) })
      .addTo(map)
      .bindPopup(`
        <strong>${s.name}</strong><br>
        ${s.temp_f ? s.temp_f + '°F · ' : ''}${s.fee != null ? (s.fee === 0 ? 'Free' : '$' + s.fee) : ''}
        <br><button onclick="window.__tp.toggle('${s.slug}')" style="margin-top:6px;padding:4px 10px;background:#2d6a4f;color:white;border:none;border-radius:4px;cursor:pointer;">
          Add to trip
        </button>
      `);
    markers.set(s.slug, m);
  });
}

// ─── Springs list ─────────────────────────────────────────────────────────────
function renderSpringsList(filter = '') {
  const el = document.getElementById('springs-list');
  const visible = springs.filter(s =>
    s.name.toLowerCase().includes(filter.toLowerCase())
  );

  if (!visible.length) { el.innerHTML = '<p class="muted">No springs found.</p>'; return; }

  el.innerHTML = visible.map(s => {
    const checked = selectedSprings.some(x => x.slug === s.slug);
    return `
      <label class="spring-check-item ${checked ? 'is-checked' : ''}">
        <input type="checkbox" data-slug="${s.slug}" ${checked ? 'checked' : ''} />
        <span class="check-name">${s.name}</span>
        <span class="check-meta">${s.temp_f ? s.temp_f + '°F' : '—'} · ${s.fee != null ? (s.fee === 0 ? 'Free' : '$' + s.fee) : '—'}</span>
      </label>
    `;
  }).join('');

  el.querySelectorAll('input[type=checkbox]').forEach(cb => {
    cb.addEventListener('change', () => toggleSpring(cb.dataset.slug));
  });
}

function renderSelectedList() {
  const el = document.getElementById('selected-list');
  const count = document.getElementById('selected-count');
  count.textContent = selectedSprings.length;

  if (!selectedSprings.length) {
    el.innerHTML = '<p class="muted">Add springs from the list above.</p>';
    document.getElementById('optimize-btn').disabled = true;
    return;
  }

  el.innerHTML = selectedSprings.map((s, i) => `
    <div class="selected-item" draggable="true" data-slug="${s.slug}">
      <span class="stop-num">${i + 1}</span>
      <span class="stop-name">${s.name}</span>
      <button class="remove-stop" data-slug="${s.slug}" title="Remove">✕</button>
    </div>
  `).join('');

  el.querySelectorAll('.remove-stop').forEach(btn => {
    btn.addEventListener('click', () => toggleSpring(btn.dataset.slug));
  });

  document.getElementById('optimize-btn').disabled = selectedSprings.length < 2 || !startLocation;
}

// ─── Toggle spring in/out of trip ─────────────────────────────────────────────
function toggleSpring(slug) {
  const spring = springs.find(s => s.slug === slug);
  if (!spring) return;
  const idx = selectedSprings.findIndex(s => s.slug === slug);
  if (idx === -1) {
    selectedSprings.push(spring);
  } else {
    selectedSprings.splice(idx, 1);
  }
  // Update marker style
  const m = markers.get(slug);
  if (m) m.setIcon(makeIcon(idx === -1));
  renderSelectedList();
  renderSpringsList(document.getElementById('spring-filter').value);
}

// ─── Geocode start location ────────────────────────────────────────────────────
async function geocodeStart(query) {
  const res = await fetch(
    `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(query)}&format=json&limit=1&countrycodes=us`
  );
  const data = await res.json();
  if (!data.length) throw new Error('Location not found');
  return { lat: parseFloat(data[0].lat), lng: parseFloat(data[0].lon), name: data[0].display_name };
}

// ─── Route optimisation ────────────────────────────────────────────────────────
async function optimizeRoute() {
  if (!startLocation || selectedSprings.length < 2) return;
  setLoading('Optimizing route…');

  try {
    // Try Google Routes API first
    let orderedSprings;
    if (CFG.googleApiKey) {
      orderedSprings = await optimizeWithGoogle();
    } else {
      orderedSprings = optimizeGeometric();
    }

    selectedSprings = orderedSprings;
    renderSelectedList();

    await drawRoute();
    showStats();
    await findPOIs();

    saveTrip();
  } catch (e) {
    console.error('Route optimization failed:', e);
    alert('Failed to optimise route — check your API keys or try fewer stops.');
  } finally {
    clearLoading();
  }
}

async function optimizeWithGoogle() {
  const waypoints = selectedSprings.map(s => ({
    location: { latLng: { latitude: s.lat, longitude: s.lng } }
  }));

  const resp = await fetch('https://routes.googleapis.com/directions/v2:computeRoutes', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-Goog-Api-Key': CFG.googleApiKey,
      'X-Goog-FieldMask': 'routes.optimizedIntermediateWaypointIndex,routes.distanceMeters,routes.duration',
    },
    body: JSON.stringify({
      origin: { location: { latLng: { latitude: startLocation.lat, longitude: startLocation.lng } } },
      destination: waypoints[waypoints.length - 1],
      intermediates: waypoints.slice(0, -1),
      optimizeWaypointOrder: true,
      travelMode: 'DRIVE',
    }),
  });

  if (!resp.ok) throw new Error(`Google Routes ${resp.status}`);
  const data = await resp.json();
  const indices = data.routes[0].optimizedIntermediateWaypointIndex ?? [];
  return indices.map(i => selectedSprings[i]).concat(selectedSprings[selectedSprings.length - 1]);
}

function optimizeGeometric() {
  // Nearest-neighbour heuristic from start location
  const unvisited = [...selectedSprings];
  const ordered = [];
  let cur = startLocation;

  while (unvisited.length) {
    let best = 0, bestDist = Infinity;
    unvisited.forEach((s, i) => {
      const d = haversineKm(cur.lat, cur.lng, s.lat, s.lng);
      if (d < bestDist) { bestDist = d; best = i; }
    });
    ordered.push(unvisited.splice(best, 1)[0]);
    cur = ordered[ordered.length - 1];
  }
  return ordered;
}

// ─── Draw route ───────────────────────────────────────────────────────────────
async function drawRoute() {
  if (routeLayer) map.removeLayer(routeLayer);

  const stops = [startLocation, ...selectedSprings];
  const coords = stops.map(s => `${s.lng},${s.lat}`).join(';');

  try {
    if (!CFG.mapboxToken) throw new Error('No Mapbox token');
    const res = await fetch(
      `https://api.mapbox.com/directions/v5/mapbox/driving/${coords}?overview=full&geometries=geojson&access_token=${CFG.mapboxToken}`
    );
    if (!res.ok) throw new Error(`Mapbox ${res.status}`);
    const data = await res.json();
    const route = data.routes[0];
    optimizedRoute = route;

    routeLayer = L.geoJSON(route.geometry, {
      style: { color: '#2d6a4f', weight: 4, opacity: 0.8 },
    }).addTo(map);

    map.fitBounds(routeLayer.getBounds().pad(0.1));

    // Numbered stop markers
    selectedSprings.forEach((s, i) => {
      const m = markers.get(s.slug);
      if (m) m.setIcon(L.divIcon({
        className: 'spring-marker',
        html: `<div class="tp-numbered">${i + 1}</div>`,
        iconSize: [28, 28], iconAnchor: [14, 14],
      }));
    });

  } catch {
    // Fallback: dashed straight lines
    const latlngs = stops.map(s => [s.lat, s.lng]);
    routeLayer = L.polyline(latlngs, {
      color: '#2d6a4f', weight: 3, dashArray: '8, 8', opacity: 0.7,
    }).addTo(map);
    map.fitBounds(routeLayer.getBounds().pad(0.1));
    optimizedRoute = null;
  }
}

// ─── Stats ────────────────────────────────────────────────────────────────────
function showStats() {
  const section = document.getElementById('route-stats');
  section.classList.remove('hidden');

  document.getElementById('stat-stops').textContent = selectedSprings.length;

  if (optimizedRoute) {
    document.getElementById('stat-distance').textContent =
      (optimizedRoute.distance / 1609.34).toFixed(0);
    document.getElementById('stat-duration').textContent =
      formatDuration(optimizedRoute.duration);
  } else {
    // Geometric estimate
    const stops = [startLocation, ...selectedSprings];
    let km = 0;
    for (let i = 0; i < stops.length - 1; i++) {
      km += haversineKm(stops[i].lat, stops[i].lng, stops[i+1].lat, stops[i+1].lng);
    }
    document.getElementById('stat-distance').textContent = (km * 0.621371).toFixed(0);
    document.getElementById('stat-duration').textContent = formatDuration(km / 80 * 3600);
  }
}

// ─── POI recommendations ──────────────────────────────────────────────────────
async function findPOIs() {
  if (!selectedSprings.length) return;

  const lats = selectedSprings.map(s => s.lat);
  const lngs = selectedSprings.map(s => s.lng);
  const south = Math.min(...lats) - 0.3;
  const north = Math.max(...lats) + 0.3;
  const west  = Math.min(...lngs) - 0.3;
  const east  = Math.max(...lngs) + 0.3;

  const query = `[out:json][timeout:20];
(
  node[amenity=restaurant](${south},${west},${north},${east});
  node[amenity=fuel](${south},${west},${north},${east});
  node[tourism=camp_site](${south},${west},${north},${east});
);
out 15;`;

  try {
    const res = await fetch(CFG.overpassUrl, {
      method: 'POST',
      body: `data=${encodeURIComponent(query)}`,
    });
    const data = await res.json();
    const pois = data.elements.filter(e => e.tags?.name).slice(0, 12);

    if (!pois.length) return;

    const section = document.getElementById('poi-section');
    section.classList.remove('hidden');

    const icons = { restaurant: '🍽', fuel: '⛽', camp_site: '🏕' };
    document.getElementById('poi-list').innerHTML = pois.map(p => `
      <div class="poi-item">
        <span>${icons[p.tags.amenity || p.tags.tourism] ?? '📍'}</span>
        <span>${p.tags.name}</span>
      </div>
    `).join('');
  } catch { /* Overpass optional */ }
}

// ─── Save / restore trip ──────────────────────────────────────────────────────
function saveTrip() {
  const key = 'co-hot-springs-trip';
  localStorage.setItem(key, JSON.stringify({
    start: startLocation,
    slugs: selectedSprings.map(s => s.slug),
  }));
}

function restoreSavedTrip() {
  try {
    const saved = JSON.parse(localStorage.getItem('co-hot-springs-trip') ?? 'null');
    if (!saved) return;
    if (saved.start) {
      startLocation = saved.start;
      document.getElementById('start-location').value = saved.start.name ?? '';
    }
    if (saved.slugs?.length) {
      saved.slugs.forEach(slug => {
        const s = springs.find(x => x.slug === slug);
        if (s) { selectedSprings.push(s); markers.get(slug)?.setIcon(makeIcon(true)); }
      });
      renderSelectedList();
    }
  } catch { /* ignore */ }
}

// ─── Share ────────────────────────────────────────────────────────────────────
function shareTrip() {
  const slugs = selectedSprings.map(s => s.slug).join(',');
  const url = new URL(window.location.href);
  url.searchParams.set('stops', slugs);
  if (startLocation) url.searchParams.set('from', `${startLocation.lat},${startLocation.lng}`);
  navigator.clipboard.writeText(url.toString()).then(() => alert('Link copied!'));
}

// ─── Event listeners ──────────────────────────────────────────────────────────
function setupListeners() {
  document.getElementById('spring-filter').addEventListener('input', e => {
    renderSpringsList(e.target.value);
  });

  document.getElementById('start-location').addEventListener('change', async e => {
    const val = e.target.value.trim();
    if (!val) { startLocation = null; return; }
    try {
      startLocation = await geocodeStart(val);
      L.marker([startLocation.lat, startLocation.lng], {
        icon: L.divIcon({
          className: 'spring-marker',
          html: '<div class="tp-start">🏠</div>',
          iconSize: [32, 32], iconAnchor: [16, 16],
        }),
      }).addTo(map).bindTooltip('Start', { permanent: true, direction: 'top' });
      map.panTo([startLocation.lat, startLocation.lng]);
      document.getElementById('optimize-btn').disabled = selectedSprings.length < 2;
    } catch { alert('Location not found — try a different address.'); }
  });

  document.getElementById('use-gps-btn').addEventListener('click', () => {
    navigator.geolocation?.getCurrentPosition(pos => {
      startLocation = { lat: pos.coords.latitude, lng: pos.coords.longitude, name: 'Your location' };
      document.getElementById('start-location').value = 'Your location';
      map.panTo([startLocation.lat, startLocation.lng]);
      document.getElementById('optimize-btn').disabled = selectedSprings.length < 2;
    }, () => alert('Could not get your location.'));
  });

  document.getElementById('optimize-btn').addEventListener('click', optimizeRoute);

  document.getElementById('clear-trip-btn').addEventListener('click', () => {
    selectedSprings.forEach(s => markers.get(s.slug)?.setIcon(makeIcon(false)));
    selectedSprings = [];
    if (routeLayer) { map.removeLayer(routeLayer); routeLayer = null; }
    renderSelectedList();
    renderSpringsList();
    document.getElementById('route-stats').classList.add('hidden');
    document.getElementById('poi-section').classList.add('hidden');
    localStorage.removeItem('co-hot-springs-trip');
  });

  document.getElementById('save-trip-btn').addEventListener('click', () => { saveTrip(); alert('Trip saved!'); });
  document.getElementById('share-trip-btn').addEventListener('click', shareTrip);

  // Expose toggle for popup buttons
  window.__tp = { toggle: toggleSpring };

  // Load from URL params
  const params = new URLSearchParams(location.search);
  if (params.get('stops')) {
    params.get('stops').split(',').forEach(slug => {
      if (springs.find(s => s.slug === slug)) toggleSpring(slug);
    });
  }
}

init();
</script>

<style>
  .planner-page {
    display: flex;
    height: calc(100vh - 60px);
    overflow: hidden;
  }

  /* Sidebar */
  .planner-sidebar {
    width: 340px;
    flex-shrink: 0;
    overflow-y: auto;
    background: var(--color-surface);
    border-right: 1px solid var(--color-border);
  }
  .sidebar-section {
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }
  .sidebar-title { font-size: 1.25rem; font-weight: 700; margin-bottom: 0.75rem; }
  .field-label { font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); display: block; margin-bottom: 0.4rem; }
  .section-header-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.6rem; }
  .section-header-row .field-label { margin-bottom: 0; }
  .section-header-row input[type=search] { width: 120px; padding: 0.3rem 0.5rem; font-size: 0.8rem; border: 1px solid var(--color-border); border-radius: 4px; }

  .start-input-row { display: flex; gap: 0.4rem; }
  .start-input-row input { flex: 1; padding: 0.5rem 0.6rem; border: 1px solid var(--color-border); border-radius: 6px; font-size: 0.875rem; }
  .start-input-row button { padding: 0.5rem 0.6rem; border: 1px solid var(--color-border); border-radius: 6px; background: var(--color-bg); cursor: pointer; }

  .springs-checklist { max-height: 220px; overflow-y: auto; }
  .spring-check-item {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.4rem 0; border-bottom: 1px solid var(--color-border); cursor: pointer;
  }
  .spring-check-item:last-child { border-bottom: none; }
  .spring-check-item.is-checked { background: #f0fdf4; margin: 0 -1.25rem; padding: 0.4rem 1.25rem; }
  .check-name { font-size: 0.875rem; font-weight: 500; flex: 1; }
  .check-meta { font-size: 0.75rem; color: var(--color-text-muted); }

  .selected-list { margin-bottom: 0.75rem; }
  .selected-item {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.4rem 0; border-bottom: 1px solid var(--color-border); font-size: 0.875rem;
  }
  .stop-num { width: 20px; height: 20px; border-radius: 50%; background: var(--color-accent); color: white; font-size: 0.7rem; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .stop-name { flex: 1; }
  .remove-stop { background: none; border: none; cursor: pointer; color: var(--color-text-muted); font-size: 0.75rem; }

  .badge { background: var(--color-accent); color: white; border-radius: 10px; padding: 0.1rem 0.4rem; font-size: 0.75rem; font-weight: 700; margin-left: 0.3rem; }
  .muted { font-size: 0.875rem; color: var(--color-text-muted); }
  .text-btn { background: none; border: none; cursor: pointer; font-size: 0.8125rem; color: var(--color-text-muted); text-decoration: underline; }
  .btn-primary { background: var(--color-accent); color: white; border: none; padding: 0.65rem 1rem; border-radius: 7px; font-size: 0.9rem; font-weight: 600; cursor: pointer; transition: background 0.15s; }
  .btn-primary:hover:not(:disabled) { background: var(--color-accent-light); }
  .btn-primary:disabled { opacity: 0.45; cursor: not-allowed; }
  .btn-secondary { background: var(--color-bg); border: 1px solid var(--color-border); padding: 0.5rem 0.75rem; border-radius: 6px; font-size: 0.8125rem; cursor: pointer; }
  .full-width { width: 100%; }
  .btn-row { display: flex; gap: 0.5rem; margin-top: 0.5rem; }

  .stats-row { display: flex; gap: 0.5rem; margin-bottom: 0.5rem; }
  .stat { flex: 1; text-align: center; background: var(--color-bg); border-radius: 8px; padding: 0.6rem 0.25rem; }
  .stat span { display: block; font-size: 1.25rem; font-weight: 700; color: var(--color-accent); }
  .stat small { font-size: 0.7rem; color: var(--color-text-muted); }

  .poi-item { display: flex; align-items: center; gap: 0.5rem; padding: 0.3rem 0; font-size: 0.85rem; border-bottom: 1px solid var(--color-border); }
  .poi-item:last-child { border-bottom: none; }

  /* Map */
