---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const {
  title,
  publishedDate,
  updatedDate,
  description,
  heroImage,
  heroImageAlt,
  heroImageCaption,
  seo,
} = post.data;

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric', month: 'long', day: 'numeric',
  });
}
---

<BaseLayout
  title={seo?.title ?? title}
  description={seo?.description ?? description}
  heroImage={heroImage}
  heroImageAlt={heroImageAlt}
  publishedDate={publishedDate}
  type="article"
>
  <article class="post-article">
    <!-- Hero image -->
    {heroImage && (
      <div class="post-hero">
        <img
          src={heroImage}
          alt={heroImageAlt ?? title}
          class="post-hero-image"
          loading="eager"
          decoding="async"
        />
        {heroImageCaption && (
          <p class="post-hero-caption">{heroImageCaption}</p>
        )}
      </div>
    )}

    <div class="container">
      <div class="post-layout">
        <header class="post-header">
          <div class="post-meta">
            <a href="/blog" class="back-link">← All posts</a>
            <time class="post-date" datetime={publishedDate}>
              {formatDate(publishedDate)}
            </time>
            {updatedDate && updatedDate !== publishedDate && (
              <span class="post-updated">
                Updated {formatDate(updatedDate)}
              </span>
            )}
          </div>
          <h1 class="post-title">{title}</h1>
          {description && <p class="post-description">{description}</p>}
        </header>

        <div class="prose post-content">
          <Content />
        </div>

        <footer class="post-footer">
          <a href="/blog" class="back-link">← Back to all posts</a>
        </footer>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .post-article { padding-bottom: 4rem; }

  /* Hero */
  .post-hero {
    width: 100%;
    max-height: 520px;
    overflow: hidden;
    margin-bottom: 3rem;
  }
  .post-hero-image {
    width: 100%;
    height: 520px;
    object-fit: cover;
  }
  .post-hero-caption {
    text-align: center;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    padding: 0.5rem 1.5rem 0;
    background: var(--color-bg);
  }

  /* Layout */
  .post-layout {
    max-width: var(--content-width);
    margin: 0 auto;
  }

  /* Header */
  .post-header { margin-bottom: 2.5rem; }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }
  .back-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted);
  }
  .back-link:hover { color: var(--color-accent); }
  .post-date {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }
  .post-updated {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    opacity: 0.75;
  }
  .post-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-bottom: 1rem;
  }
  .post-description {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
  }

  /* Content */
  .post-content { margin-bottom: 3rem; }

  /* Footer */
  .post-footer { padding-top: 2rem; border-top: 1px solid var(--color-border); }
</style>
